# Copy to .env.local (dev) or set in your host's build env (production).

# Build the app as the PUBLIC READ-ONLY VIEWER:
#   1 = read-only; loads client/public/graph.json, hides all editing.
#   unset/0 = authoring mode (localStorage, full editor) — the default for dev.
VITE_PUBLIC_READONLY=

# Optional donation link shown in the read-only viewer (footer + header).
# e.g. https://github.com/sponsors/you  or  https://ko-fi.com/you
VITE_DONATE_URL=
